# -------------------------------
# N1 Production Environment
# -------------------------------

# HTTP
PORT=3000
WEB_DIR=/app/web
DB_PATH=/app/data/shop.db

# N1 low-write profile (recommended)
STORAGE_PROFILE=low_write
ACCESS_LOG=false
GIN_MODE=release

# Store
STORE_NAME=My Store

# Admin login
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeToStrongPassword123

# JWT (must change)
JWT_SECRET=ChangeToVeryLongRandomSecretAtLeast32Chars
TOKEN_TTL_HOURS=720

# Print
AUTO_PRINT=true

# Printer mode: stdout | file | tcp
PRINTER_MODE=file

# USB thermal printer (common on Debian)
PRINTER_DEVICE=/dev/usb/lp0

# For network printer only (if PRINTER_MODE=tcp)
PRINTER_TCP=

# CORS
# If front-end is hosted on Cloudflare Pages, use exact origin.
# Example: https://shop01.pages.dev
CORS_ORIGIN=*

# Optional: Cloudflare Tunnel token (for docker-compose.tunnel.yml)
CF_TUNNEL_TOKEN=
