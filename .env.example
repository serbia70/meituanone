PORT=3000
WEB_DIR=/app/web
DB_PATH=/app/data/shop.db

# balanced | low_write
STORAGE_PROFILE=low_write

# 访问日志写入容器日志文件，N1 推荐 false
ACCESS_LOG=false

# debug | release
GIN_MODE=release

STORE_NAME=My Store

ADMIN_USER=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=change-this-secret
TOKEN_TTL_HOURS=720

AUTO_PRINT=true

# 打印机模式: stdout | file | tcp
PRINTER_MODE=stdout

# PRINTER_MODE=file 时生效，例如 /dev/usb/lp0
PRINTER_DEVICE=/dev/usb/lp0

# PRINTER_MODE=tcp 时生效，例如 192.168.1.50:9100
PRINTER_TCP=

# 允许跨域来源，生产建议写具体域名
CORS_ORIGIN=*

# Optional: Cloudflare Tunnel token (for docker-compose.tunnel.yml)
CF_TUNNEL_TOKEN=
