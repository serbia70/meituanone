# Store identity
SHOP_CODE=__SHOP_CODE__
STORE_NAME=__STORE_NAME__
PUBLIC_DOMAIN=__PUBLIC_DOMAIN__

# Port mapping on host
SHOP_PORT=__SHOP_PORT__

# App runtime
PORT=3000
WEB_DIR=/app/web
DB_PATH=/app/data/shop.db
STORAGE_PROFILE=low_write
ACCESS_LOG=false
GIN_MODE=release

# Admin
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeToStrongPassword123
JWT_SECRET=ChangeToVeryLongRandomSecretAtLeast32Chars
TOKEN_TTL_HOURS=720

# Printing
AUTO_PRINT=true
PRINTER_MODE=file
PRINTER_DEVICE=/dev/usb/lp0
PRINTER_TCP=

# CORS
CORS_ORIGIN=*

# Cloudflare tunnel
CF_TUNNEL_TOKEN=
